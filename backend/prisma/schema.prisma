generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Veiculo {
  id            String   @id @default(cuid())
  titulo        String
  marca         String
  modelo        String
  ano           Int
  preco         Float
  quilometragem Int
  combustivel   String
  tipo          String
  cor           String
  descricao     String?
  vendido       Boolean  @default(false)
  imagens       Imagem[]
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Imagem {
  id         String  @id @default(cuid())
  url        String
  ehPrimaria Boolean @default(false)
  veiculoId  String
  veiculo    Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  criadoEm DateTime @default(now())
}